{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.23.0",
    "generators": {
      "typescript-angular": {
        "generatorName": "typescript-angular",
        "inputSpec": "../openapi/api.yaml",
        "output": "src/app/api",
        "additionalProperties": {
          "ngVersion": "21",
          "supportsES6": true,
          "withInterfaces": true,
          "enumPropertyNaming": "original"
        }
      }
    }
  }
}
